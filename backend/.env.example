# AiMaster 后端配置示例
# 复制此文件为 .env 并修改配置

# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/aimaster

# JWT 密钥（生产环境请使用复杂的随机字符串）
SECRET_KEY=your-secret-key-change-this-in-production

# MiniMax API 配置
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_MODEL=MiniMax-M2.5

# AI 模式：true=模拟模式（不消耗API配额）, false=真实API
AI_MOCK_MODE=true

# 管理员密码
ADMIN_PASSWORD=admin123

# 调试模式
DEBUG=false
